# Python Backend Environment Variables

# Firebase Admin SDK (use one of the following)
# Option 1: Path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
# Option 2: Full JSON content as a single-line string (recommended for Railway)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Gemini API key (required for AI generation)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: multiple Gemini keys for rotation, comma-separated
# GEMINI_API_KEYS=key1,key2,key3

# Speech-to-Text API (Optional - for audio file transcription)
# Get free API key from: https://www.assemblyai.com/dashboard/signup
# Free tier: 5 hours/month
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here
